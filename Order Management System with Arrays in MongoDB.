db.orders.insertMany([
  {
    orderId: 101,
    userId: "U001",
    items: [
      { product: "Laptop", quantity: 1, price: 55000 },
      { product: "Mouse", quantity: 2, price: 500 }
    ],
    totalAmount: 56000,
    status: "placed"
  },
  {
    orderId: 102,
    userId: "U002",
    items: [
      { product: "Smartphone", quantity: 1, price: 15000 },
      { product: "Headphones", quantity: 1, price: 1200 }
    ],
    totalAmount: 16200,
    status: "shipped"
  },
  {
    orderId: 103,
    userId: "U001",
    items: [
      { product: "Backpack", quantity: 1, price: 800 }
    ],
    totalAmount: 800,
    status: "cancelled"
  }
]);

//Retrieve orders placed by a specific user
db.orders.find({ userId: "U001" });

//Add a new item to an existing order using $push
db.orders.updateOne(
  { orderId: 101 },
  {
    $push: {
      items: { product: "Keyboard", quantity: 1, price: 1500 }
    }
  }
);

//Update the total amount of an order
db.orders.updateOne(
  { orderId: 101 },
  { $set: { totalAmount: 57500 } }
);

//Delete orders with status "cancelled"
db.orders.deleteMany({ status: "cancelled" });
















